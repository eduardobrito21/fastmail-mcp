# Fastmail API token (Bearer) — create at https://www.fastmail.com/dev/
FASTMAIL_API_TOKEN=

# JMAP session URL (default matches Fastmail docs)
# FASTMAIL_JMAP_SESSION_URL=https://api.fastmail.com/jmap/session

# HTTP transport only: when false, the server never reads FASTMAIL_API_TOKEN from env for HTTP
# requests — callers must send X-Fastmail-Api-Token or ?fastmail_api_token= (multi-tenant hosting).
# FASTMAIL_MCP_HTTP_ALLOW_ENV_API_KEY=false
